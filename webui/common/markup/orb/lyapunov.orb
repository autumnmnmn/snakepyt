
$title { Lyapunov Fractals }

$og_image { /media/lyapunov/preview.png }

$og_description { Exploring and explaining Mario Markus's logistic Lyapunov fractals }

$css {
    .gallery img {
        width: calc(max(25vw, 64px) - 0.5em);
        height: calc(max(25vw, 64px) - 0.5em);
        padding: 0;
        border-radius: 0.25rem;
        border: 0.25rem solid transparent;
    }

    .gallery img:hover {
        border: 0;
        clip-path: inset(0) !important;
    }

    .gallery {
        margin-top: 0.5rem;
        display: flex;
        flex-wrap: wrap;
        align-content: flex-start;
        gap: 0px;
        width: fit-content;
    }

    .blog-content {
        margin-left: 1em;
        padding-right: 1em;

        height: 100%;
        overflow-y: scroll;
    }

    @media (min-width: 600px) {
        .gallery img {
            width: calc(max(min(25vw, 512px), 256px) - 0.875em);
            height: calc(max(min(25vw, 512px), 256px) - 0.875em);
        }

        .gallery {
            gap: 0.5em;
        }
    }

    .center {
        display: block;
        margin: auto;
        width: fit-content;
    }

    .gallery img:not(.loaded) {
        filter: url(#thumb-blur);
        clip-path: inset(0.25rem);
    }

    #lightbox {
        display: none;
        position: fixed;
        inset: 0;
        background: #000a;
        place-items: center;
        z-index: 2;
    }

    #lightbox.open {
        display: grid;
    }

    #lightbox img {
        max-width: 98vw;
        max-height: 98vh;
        object-fit: contain;
    }
}

[id=lightbox| onclick=this.classList.remove('open')] {
    img[id=lightbox-img]{}
}

svg[style=height:0;width:0;margin:0;padding:0;display:block] {
  filter[id=thumb-blur] {
    feGaussianBlur[stdDeviation=3 | edgeMode=duplicate]{}
  }
}

